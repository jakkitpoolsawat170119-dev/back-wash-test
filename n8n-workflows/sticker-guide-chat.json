    {
      "parameters": {
        "mode": "runOnceForAllItems",
        "jsCode": "// ประกอบคำตอบ: ข้อความขั้นตอน + รูปภาพประกอบ\nconst guide = $input.first().json;\nconst customerName = guide.customer_name;\n\n// guide.steps เก็บเป็นข้อความหลายบรรทัด เช่น \"1. แกะสติ๊กเกอร์...\\n2. วาง...\"\nconst stepsText = `📦 วิธีติดสติ๊กเกอร์สำหรับลูกค้า ${customerName}\\n\\n${guide.steps}`;\n\n// guide.image_urls เป็น array ของ URL รูปตัวอย่างขั้นตอน\nconst imageUrls = Array.isArray(guide.image_urls) ? guide.image_urls : [];\n\nconst messages = [\n  { type: 'text', text: stepsText },\n  ...imageUrls.map((url) => ({ type: 'image', url }))\n];\n\nreturn [{ json: { messages } }];"
      },
      "id": "format-found-reply",
      "name": "จัดรูปแบบคำตอบ (พบข้อมูล)",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        640,
        -220
      ]
    },
    {
      "parameters": {
        "mode": "runOnceForAllItems",
        "jsCode": "const customerName = $('ดึงชื่อลูกค้าจากข้อความ').first().json.customerName;\n\nreturn [{\n  json: {\n    messages: [\n      {\n        type: 'text',\n        text: `ขออภัยค่ะ ยังไม่มีข้อมูลวิธีติดสติ๊กเกอร์สำหรับลูกค้า \"${customerName}\" ในระบบ\\nรบกวนติดต่อแอดมินเพื่อขอข้อมูลเพิ่มเติมนะคะ 🙏`\n      }\n    ]\n  }\n}];"
      },
      "id": "format-not-found-reply",
      "name": "จัดรูปแบบคำตอบ (ไม่พบข้อมูล)",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        640,
        -20
      ]
    },
    {
      "parameters": {
        "mode": "runOnceForAllItems",
        "jsCode": "return [{\n  json: {\n    messages: [\n      {\n        type: 'text',\n        text: 'รบกวนระบุชื่อลูกค้าด้วยนะคะ เช่น \"วิธีติดสติ๊กเกอร์ลูกค้า Kaoshop\" เพื่อให้ระบบค้นหาขั้นตอนการติดสติ๊กเกอร์ให้ถูกต้องค่ะ'\n      }\n    ]\n  }\n}];"
      },
