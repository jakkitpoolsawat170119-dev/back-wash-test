    },
    {
      "parameters": {
        "mode": "runOnceForAllItems",
        "jsCode": "// ดึงชื่อลูกค้าออกจากข้อความ เช่น \"วิธีติดสติ๊กเกอร์ลูกค้า Kaoshop\" -> \"Kaoshop\"\nconst body = $input.first().json.body || {};\nconst message = (body.message || '').toString().trim();\n\n// รองรับทั้ง \"ลูกค้า <ชื่อ>\" และ \"ลูกค้าชื่อ <ชื่อ>\"\nconst match = message.match(/ลูกค้า(?:ชื่อ)?\\s*([A-Za-zก-๙0-9_-]+)/);\nconst customerName = match ? match[1].trim() : '';\n\nreturn [{\n  json: {\n    message,\n    customerName,\n    sessionId: body.sessionId || null\n  }\n}];"
      },
      "id": "extract-customer-name",
      "name": "ดึงชื่อลูกค้าจากข้อความ",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        -240,
        0
      ]
    },
    {
      "parameters": {
        "conditions": {
          "options": {
            "caseSensitive": true,
            "leftValue": "",
            "typeValidation": "strict"
          },
          "conditions": [
            {
              "id": "has-customer-name",
              "leftValue": "={{ $json.customerName }}",
              "rightValue": "",
              "operator": {
                "type": "string",
                "operation": "notEmpty"
              }
            }
          ],
          "combinator": "and"
        },
        "options": {}
      },
      "id": "if-has-customer-name",
      "name": "พบชื่อลูกค้าในข้อความหรือไม่?",
      "type": "n8n-nodes-base.if",
      "typeVersion": 2,
